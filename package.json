{
  "name": "teamwork-homenursing-backend",
  "version": "1.0.0",
  "description": "Enterprise-grade Node.js backend for Teamwork Physiotherapy Centre International",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --legacy-watch --polling-interval 1000 src/server.ts",
    "predev": "npm run db:generate",
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "db:generate": "cross-env NODE_OPTIONS=--max-old-space-size=512 prisma generate",
    "db:push": "cross-env NODE_OPTIONS=--max-old-space-size=512 prisma db push",
    "db:migrate": "cross-env NODE_OPTIONS=--max-old-space-size=512 prisma migrate dev",
    "db:migrate:prod": "cross-env NODE_OPTIONS=--max-old-space-size=512 prisma migrate deploy",
    "db:seed": "node --max-old-space-size=512 node_modules/ts-node/dist/bin.js prisma/seed.ts",
    "script:backfill-usernames": "node --max-old-space-size=512 node_modules/ts-node/dist/bin.js scripts/backfill-usernames.ts",
    "script:clean-database": "node --max-old-space-size=512 node_modules/ts-node/dist/bin.js scripts/clean-database.ts",
    "script:remove-seed-data": "node --max-old-space-size=512 node_modules/ts-node/dist/bin.js scripts/remove-seed-data.ts",
    "db:seed:staff": "node --max-old-space-size=512 node_modules/ts-node/dist/bin.js scripts/seed-staff.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "docs:generate": "swagger-jsdoc -d swaggerDef.js src/routes/**/*.ts -o docs/api/swagger.json",
    "docs:serve": "swagger-ui-serve docs/api/swagger.json",
    "backup:db": "node scripts/backup.js",
    "restore:db": "node scripts/restore.js",
    "health:check": "node -e \"fetch('http://localhost:3847/api/v1/health').then(r=>r.text()).then(t=>console.log(t)).catch(e=>{console.error(e?.message||e);process.exit(1);})\"",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "homecare",
    "healthcare",
    "management-system",
    "nodejs",
    "typescript",
    "express",
    "prisma",
    "postgresql"
  ],
  "author": "Teamwork Homecare",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "5.22.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-brute": "^1.0.1",
    "express-prometheus-middleware": "^1.2.0",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^2.0.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "joi-password-complexity": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "pdf-lib": "^1.17.1",
    "prom-client": "^13.2.0",
    "sanitize-html": "^2.11.0",
    "sharp": "^0.33.1",
    "socket.io": "^4.7.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^4.19.3",
    "uuid": "^9.0.1",
    "validator": "^13.11.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/lodash": "^4.14.202",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/sanitize-html": "^2.9.5",
    "@types/supertest": "^2.0.16",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.7",
    "@types/validator": "^13.11.7",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "cross-env": "^7.0.3",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "nodemon": "^3.0.2",
    "openapi-types": "12.1.3",
    "prettier": "^3.1.0",
    "prisma": "5.22.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/teamwork/homecare-backend.git"
  },
  "bugs": {
    "url": "https://github.com/teamwork/homecare-backend/issues"
  },
  "homepage": "https://github.com/teamwork/homecare-backend#readme"
}
