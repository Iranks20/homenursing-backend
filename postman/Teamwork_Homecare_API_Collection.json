            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"role\": \"nurse\",\n  \"phone\": \"+1234567890\",\n  \"department\": \"Emergency Care\"\n}"
