# Server
PORT=3007
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres123@localhost:5433/teamwork_homecare?schema=public

# JWT
JWT_SECRET=change-me-long-random
JWT_REFRESH_SECRET=change-me-long-random-2
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated origins, no trailing slashes)
CORS_ORIGIN=http://localhost:5291,http://localhost:5173,http://localhost:3847,https://homenursing-frontend-production.up.railway.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=100000
RATE_LIMIT_MAX=100000
ENABLE_RATE_LIMITING=false
ENABLE_RATE_LIMIT=true

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@teamwork-homecare.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=teamwork-homecare-files
AWS_REGION=us-east-1

# File Uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Feature Flags
ENABLE_REAL_TIME=true
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true

# External Services
SMS_SERVICE_URL=https://api.twilio.com
EMAIL_SERVICE_URL=https://api.sendgrid.com
PAYMENT_SERVICE_URL=https://api.stripe.com

# Debug / Logging
DEBUG=false
LOG_LEVEL=info

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-key

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Backups
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

